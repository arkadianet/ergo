/**
 * Five SigmaProp params whose HashTrieMap iteration order (2.12) differs from
 * both declaration and alphabetical order — the recon's p5 discriminator.
 */
@contract def gate5h(zeta: SigmaProp, alpha: SigmaProp, mike: SigmaProp, bravo: SigmaProp, oscar: SigmaProp) = zeta && alpha && mike && bravo && oscar
